# ============================================
# Intelletrics — root .gitignore
# One file handles both frontend/ and backend/.
# ============================================

# ---------- OS / editor ----------
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ---------- Secrets / env ----------
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ============================================
# Frontend (Next.js + Tailwind + shadcn)
# ============================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/
frontend/.vercel/
frontend/coverage/
frontend/.pnpm-store/

# next.js types
frontend/next-env.d.ts
frontend/*.tsbuildinfo

# debug logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/.pnpm-debug.log*

# ============================================
# Backend (Python / FastAPI / Pandas)
# ============================================
backend/.venv/
backend/venv/
backend/env/
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/.ruff_cache/
backend/.mypy_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/dist/
backend/build/
backend/*.egg-info/
backend/.db/
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/*.csv
backend/*.xlsx

# Jupyter (if you use notebooks for profiling)
backend/.ipynb_checkpoints/

# ============================================
# Shared
# ============================================
*.log
logs/
tmp/
temp/
.DS_Store
